.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Whether you use PnP or not, the node_modules folder is often used to store
# build artifacts that should be gitignored
node_modules

# Swap the comments on the following lines if you wish to use zero-installs
# In that case, don't forget to run `yarn config set enableGlobalCache false`!
# Documentation here: https://yarnpkg.com/features/caching#zero-installs

#!.yarn/cache
.pnp.*

node_modules
.nuxt
.output
dist
.turbo
.yarn/cache
.yarn/unplugged
.env
*.local

# MF remotes build artifacts (copied from apps/*/dist during build)
apps/host/public/remotes/


# Module Federation temp files
**/.mftemp/
**/__mf__temp/
**/.__mf__temp/

# Vite cache & build artifacts
**/.vite/
**/.vite-temp/
**/dist/

# Turbo cache
.turbo/

# Node modules
**/node_modules/

# Nuxt artifacts (legacy)
**/.nuxt/
**/.output/

# Nitro relay
apps/relay/.nitro/