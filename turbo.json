{
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "build:copy": {
      "dependsOn": ["build"],
      "cache": false,
      "outputs": []
    },
    "@glass/host#build": {
      "dependsOn": ["@glass/friends#build:copy", "@glass/chat#build:copy"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    }
  }
}
